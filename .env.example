# ============ required ============

# Supabase project settings -> API
# Example: https://abcdefghijkl.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "anon" / "public" API key (NOT the service_role key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL, used for SEO / OpenGraph tags and email links.
# Locally: http://localhost:3000  ·  In production: https://karkooba.store
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============ optional: chat email notifications ============
# Without these the app works fine — users just don't get an email
# when they receive a chat message.

# Supabase project settings -> API -> service_role key (KEEP SECRET, server-only)
SUPABASE_SERVICE_ROLE_KEY=

# https://resend.com -> API Keys (free tier)
RESEND_API_KEY=

# Verified sender, e.g. "KARKOOBA <hello@your-domain.com>"
# (falls back to Resend's onboarding sender if unset)
EMAIL_FROM=
